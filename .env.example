APP_NAME="EventManagerFree"
# BRAND_COMPANY=LucrativeIt
# BRAND_PROJECT=EventManagerFree

# Link shown on Purchase Pro / premium badges (Event Manager Plus product page)
# EDITION_PREMIUM_URL=https://lucrativeit.com/products/event-manager-plus

# Deploy: browse to /install for the setup wizard; or php artisan install:lock if already migrated.
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Include scheme, host, and port exactly as in the browser (payment return URLs depend on this).
# Examples: http://127.0.0.1:8000   or   http://localhost:8000
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Used by AdminUserSeeder (web installer writes these from App\Support\Installer\SeededAdminCredentials)
# ADMIN_EMAIL=admin@eventflow.com
# ADMIN_PASSWORD=password
# ADMIN_NAME=Admin User

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# After install, optionally: SESSION_DRIVER=database, CACHE_STORE=database, QUEUE_CONNECTION=database (requires migrations run).
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# PayPal HTTP (Windows/Laragon): cURL error 77 = bad or missing CA bundle in php.ini.
# Download https://curl.se/ca/cacert.pem and set an absolute path (forward slashes OK):
# PAYPAL_CACERT_PATH=C:/path/to/cacert.pem
# Last resort on localhost only (insecure):
# PAYPAL_VERIFY_SSL=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Legacy / fallback for AI reports (when site_settings.report_ai_* columns are missing).
# Prefer Admin → Settings → AI reports for provider, model, keys, and toggle.
#
# REPORT_AI_ENABLED=false
# OPENAI_API_KEY=
# OPENAI_API_BASE_URL=https://api.openai.com/v1
# REPORT_AI_MODEL=gpt-4o-mini
# REPORT_AI_TIMEOUT=60
# REPORT_AI_MAX_QUESTION=900
# REPORT_AI_MAX_ROWS=500
